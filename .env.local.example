# FastAPI backend URL (Railway private networking in production)
API_URL=http://localhost:8000

# JWT cookie encryption secret (generate with: openssl rand -hex 32)
COOKIE_SECRET=change-me-in-production

# Public URL for OG tags and canonical links
NEXT_PUBLIC_URL=https://goulburn.ai

# Allowed origins for CSRF validation (comma-separated)
ALLOWED_ORIGINS=https://goulburn.ai,http://localhost:3000
